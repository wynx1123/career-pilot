# =============================================================================
# CAREER PILOT - BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Port the backend server listens on
# Type: number
PORT=5000

# Runtime environment - controls logging, error detail, and optimizations
# Type: string | values: development | staging | production
NODE_ENV=development

# URL of the frontend app - used for CORS allow-list
# Type: string (URL)
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# DATABASE - MONGODB
# -----------------------------------------------------------------------------

# MongoDB connection string (local or Atlas)
# Type: string (URI)
# Atlas format: mongodb+srv://<user>:<password>@cluster.mongodb.net/career-pilot
MONGODB_URI=mongodb://localhost:27017/career-pilot

# Enable slow-query logging - set to true only in dev/staging, never in production
# Type: boolean
ENABLE_DB_PROFILING=false


# -----------------------------------------------------------------------------
# FIREBASE ADMIN SDK
# -----------------------------------------------------------------------------

# Firebase project ID (found in Firebase Console > Project Settings)
# Type: string
FIREBASE_PROJECT_ID=xxxxxxxxxxxxxxxx

# Firebase Storage bucket name
# Type: string
FIREBASE_STORAGE_BUCKET=xxxxxxxxxxxxxxxx.appspot.com

# Path to downloaded service account JSON key file
# Type: string (file path)
# Download from: Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/service-account-key.json


# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------

# Google Gemini API key - used for resume enhancement and AI interviews
# Type: string
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API key - used as a fast inference alternative
# Type: string
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# JOB SEARCH - RAPIDAPI
# -----------------------------------------------------------------------------

# RapidAPI key for the JSearch job listings API
# Type: string
# Get from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RapidAPI host for the job search endpoint
# Type: string
RAPIDAPI_HOST=jsearch.p.rapidapi.com


# -----------------------------------------------------------------------------
# EMAIL - NODEMAILER
# -----------------------------------------------------------------------------

# Sender address for job alert emails
# Type: string (email)
EMAIL_USER=no-reply@example.com

# SMTP password or app-specific password
# Type: string
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# SMTP server hostname
# Type: string
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
# Type: number
EMAIL_PORT=587

# External email microservice URL (used in staging/production)
# Type: string (URL)
EMAIL_SERVICE_URL=https://email-service.example.com

# API key to authenticate requests to the email microservice
# Type: string
EMAIL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# REDIS - JOB QUEUE (BULLMQ)
# -----------------------------------------------------------------------------

# Redis connection URL - used by BullMQ for background job processing
# Type: string (URI)
# Upstash format: rediss://:password@host:port
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Time window for rate limiting in milliseconds (default: 15 minutes)
# Type: number
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests allowed per window per IP
# Type: number
RATE_LIMIT_MAX_REQUESTS=100


# -----------------------------------------------------------------------------
# JOB ALERT SCHEDULER
# -----------------------------------------------------------------------------

# Cron schedule for running job alert checks (default: every 6 hours)
# Type: string (cron expression)
ALERT_CRON_SCHEDULE="0 */6 * * *"

# Override interval in ms for testing alerts locally - leave empty in production
# Type: number | leave blank to disable
ALERT_TEST_INTERVAL=


# -----------------------------------------------------------------------------
# PAYMENTS - RAZORPAY
# -----------------------------------------------------------------------------

# Razorpay Key ID - use rzp_test_ prefix for test mode
# Type: string
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# Razorpay Key Secret - keep this strictly server-side, never expose to frontend
# Type: string
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# LINKEDIN OAUTH
# -----------------------------------------------------------------------------

# LinkedIn OAuth App Client ID
# Type: string
# Register at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxx

# LinkedIn OAuth App Client Secret
# Type: string
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URI registered in LinkedIn app settings
# Type: string (URL)
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback


# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------

# 64-character hex key used to encrypt TOTP secrets
# Type: string (64-char hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT ONLY - never set these to true in production
# -----------------------------------------------------------------------------

# Bypass Firebase auth verification for local testing
# Type: boolean
DEV_BYPASS_AUTH=false

# UID to use when auth bypass is enabled
# Type: string
DEV_USER_UID=dev-user-001

# Email to use when auth bypass is enabled
# Type: string (email)
DEV_USER_EMAIL=dev@example.com